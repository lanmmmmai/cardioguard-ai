{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/seo.js": {
      "includeFiles": "dist/index.html"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://* wss://*; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/proxy.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/seo?path=/$1" }
  ]
}
