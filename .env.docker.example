# Copy this file to .env or keep your existing .env/backend/.env.
# docker-compose.yml reads .env and backend/.env if they exist.

# Backend
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
EXPOSE_DEV_OTP=false
IOT_DEVICE_SHARED_TOKEN=
OPENAI_API_KEY=

# Email providers
BREVO_API_KEY=
EMAIL_FROM_EMAIL=noreply@cardioguard.ai
EMAIL_FROM_NAME=CardioGuard AI
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=

# Web build args used by Docker Compose.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/realtime
