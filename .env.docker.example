# ==============================================================================
# CARDIO GUARD AI - DOCKER & LOCAL CONFIGURATION TEMPLATE (.env.example)
#
# HƯỚNG DẪN SỬ DỤNG:
# 1. Sao chép (copy) file này thành `.env` ở thư mục gốc và `backend/.env`.
# 2. Thay đổi các biến dưới đây thành cấu hình thực tế của bạn.
# ==============================================================================

# [DATABASE CONFIGURATION]
# Đường dẫn kết nối tới PostgreSQL (ví dụ kết nối tới Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://username:password@host:port/database

# [SUPABASE SERVICE CONFIGURATION]
# Các biến cấu hình Supabase (Dùng ở Backend/Frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ==============================================================================
# CHOOSE ENVIRONMENT CONFIGURATION:
# Mở/khóa bình luận (Uncomment/Comment) khối cấu hình bạn muốn sử dụng dưới đây.
# ==============================================================================

# --- CONFIG A: DEVELOPMENT (LOCAL TEST / DEV DOCKER) ---
ENVIRONMENT=development
PORT=8000
EXPOSE_DEV_OTP=true

# Host máy chủ gửi mail SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME="CardioGuard AI"
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Tên hiển thị người gửi thông qua dịch vụ Brevo
EMAIL_FROM_NAME="CardioGuard AI"

# Địa chỉ API URL của Backend để Frontend React kết nối tới (Localhost)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/realtime


# --- CONFIG B: PRODUCTION (ONLINE TEST / PRODUCTION DOCKER) ---
# ENVIRONMENT=production
# PORT=8000
# EXPOSE_DEV_OTP=false

# # Host máy chủ gửi mail SMTP (Brevo Relay)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_USERNAME=noreply@yourdomain.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_NAME="CardioGuard AI"
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# # Tên hiển thị người gửi thông qua dịch vụ Brevo
# EMAIL_FROM_NAME="CardioGuard AI"

# # Địa chỉ API URL của Backend để Frontend React kết nối tới (Online Render)
# VITE_API_URL=https://your-backend-app.onrender.com
# VITE_WS_URL=wss://your-backend-app.onrender.com/ws/realtime

# ==============================================================================

# [BREVO EMAIL SERVICE CONFIGURATION]
# API Key của dịch vụ gửi email Brevo (Sendinblue)
BREVO_API_KEY=your-brevo-api-key
# Email gửi đi thông qua dịch vụ Brevo
EMAIL_FROM_EMAIL=noreply@yourdomain.com

# [AI INTEGRATION CONFIGURATION]
# API Key của dịch vụ OpenAI dùng để phân tích chẩn đoán sức khỏe bằng AI GPT
OPENAI_API_KEY=your-openai-api-key

# [GOOGLE AUTHENTICATION CONFIGURATION]
# Client ID đăng nhập bằng Google trên Frontend/Backend
VITE_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_ID=your-google-client-id

# [SYSTEM / SECURITY CONFIGURATION]
# Khóa bảo mật dùng để ký mã hóa JWT Tokens của hệ thống (yêu cầu độ dài >= 32 ký tự)
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-characters
# Thời hạn hết hạn của Access Token (tính bằng phút)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# [IOT DEVICE AUTHENTICATION]
# Token dùng chung để xác thực thiết bị phần cứng ESP32-S3 gửi dữ liệu lên
IOT_DEVICE_SHARED_TOKEN=your-iot-device-shared-token
